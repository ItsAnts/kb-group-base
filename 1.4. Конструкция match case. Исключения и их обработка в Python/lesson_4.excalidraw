      "versionNonce": 833796198,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1774600716103,
      "link": null,
      "locked": false,
      "text": "temperature: int = int(input(\"Введите значение температуры: \"))\nunit: str = input(\"Введите единица измерения C | F: \"\n\nmatch unit:\n    case \"F\":\n       c: float = (temperature - 32) * (9/5)\n       print(\"{}{}={c}C\")\n    case \"C\":\n        f: float = (temperature * (9/5)) + 35\n        print(\"{}{}={f}F\")\n    case _:\n        print(\"Ошибка формата. Используйте например '25C' или '77F')",
      "fontSize": 28,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "temperature: int = int(input(\"Введите значение температуры: \"))\nunit: str = input(\"Введите единица измерения C | F: \"\n\nmatch unit:\n    case \"F\":\n       c: float = (temperature - 32) * (9/5)\n       print(\"{}{}={c}C\")\n    case \"C\":\n        f: float = (temperature * (9/5)) + 35\n        print(\"{}{}={f}F\")\n    case _:\n        print(\"Ошибка формата. Используйте например '25C' или '77F')",
      "autoResize": true,
      "lineHeight": 1.25
    },
