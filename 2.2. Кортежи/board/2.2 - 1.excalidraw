      "link": null,
      "locked": false,
      "text": "numbers = (1, 2, [5,5,3], 3)\nnumbers[0] = 5 # я получу ошибку, потому что пытаюсь изменить значение кортежа\nnumbers[2] = 3 # я получу ошибку, потому что пытаюсь изменить значение кортежа\nnumbers[2].append(3) # Код выполнился и будет:\n# numbers => (1, 2, [5, 5, 3, 3], 3)",
      "fontSize": 28,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "numbers = (1, 2, [5,5,3], 3)\nnumbers[0] = 5 # я получу ошибку, потому что пытаюсь изменить значение кортежа\nnumbers[2] = 3 # я получу ошибку, потому что пытаюсь изменить значение кортежа\nnumbers[2].append(3) # Код выполнился и будет:\n# numbers => (1, 2, [5, 5, 3, 3], 3)",
