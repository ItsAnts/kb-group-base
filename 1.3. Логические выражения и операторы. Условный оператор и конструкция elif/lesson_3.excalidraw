      "type": "text",
      "x": 392.1536179563724,
      "y": 1744.9449180478439,
      "width": 866.9076712482139,
      "height": 218.31713562712537,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "#ffc9c9",
