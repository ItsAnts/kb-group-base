      "seed": 132484432,
      "version": 281,
      "versionNonce": 937982384,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1774339901783,
      "link": null,
      "locked": false,
      "text": "Напиши программу, которая\nопределяет, является ли\nвведенный",
      "fontSize": 58.217902833900105,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Напиши программу, которая определяет, является ли введенный",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "Ltc2K1NoCdMyYzcIvrxHZ",
      "type": "text",
      "x": 395.70687253058196,
      "y": 1991.843584905126,
      "width": 592.6367018233823,
      "height": 145.54475708475024,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "#ffc9c9",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bFW",
      "roundness": null,
      "seed": 2097196976,
      "version": 299,
      "versionNonce": 1913504688,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1774339901783,
      "link": null,
      "locked": false,
      "text": "пользоваталем год\nвисокосным.",
      "fontSize": 58.217902833900105,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "пользоваталем год високосным.",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "kP6dnGlakb2CLI2SBE6fw",
      "type": "text",
      "x": 381.878061791895,
      "y": 2189.1026855461146,
      "width": 866.9076712482139,
      "height": 218.31713562712537,
      "angle": 0,
      "strokeColor": "#1971c2",
      "backgroundColor": "#ffc9c9",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bFX",
      "roundness": null,
      "seed": 1416061776,
      "version": 292,
      "versionNonce": 217697712,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1774339901783,
      "link": null,
      "locked": false,
      "text": "Год считается високосным,\nесли выполняется ОДНО ИЗ\nУСЛОВИЙ:",
      "fontSize": 58.217902833900105,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Год считается високосным, если выполняется ОДНО ИЗ УСЛОВИЙ:",
      "autoResize": false,
      "lineHeight": 1.25
    },
    {
      "id": "Uboz3bfHLx-GY81kKvGsT",
      "type": "text",
      "x": 456.07672217297204,
      "y": 2477.1035770613057,
      "width": 711.6599797097414,
      "height": 145.54475708475024,
      "angle": 0,
      "strokeColor": "#1971c2",
