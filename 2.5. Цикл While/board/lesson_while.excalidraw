      "text": "bucket_potatos: list[str] = [\"potato_1\", \"potato_2\", \"potato_3\", \"potato_4\", \"potato_n\"]\nbasin_clear_potatos: list[str] = []\nindex: int = len(bucket_potatos) - 1\nwhile index != -1:\n    # беру картошку из ведра\n    if bucket_potatos[index][ПОРЧЕННАЯ]?:\n        bucket_potatos.pop(index)\n        continue\n    else:\n        basin_clear_potatos.append(bucket_potatos[index])\n        bucket_potatos.pop(index)",
