    {
      "id": "7BFGJjYiKuC3Qm2XmyHJv",
      "type": "text",
      "x": 1128,
      "y": 40.5,
      "width": 741.2000122070312,
      "height": 595,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "a5",
      "roundness": null,
      "seed": 1514399380,
      "version": 54,
      "versionNonce": 917646892,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1775738522200,
      "link": null,
      "locked": false,
      "text": "\ndef debug_decorator(func):\n    \n    def wrapper(*args, **kwargs):\n        print(\"Вызов функции: \", func.__name__)\n        print(\"Аргументы: \", args, kwargs)\n        result = func(*args, **kwargs)\n        print(\"Результат: \", result)\n        return result\n    return wrapper\n    \n\n@debug_decorator\ndef add_numbers(x: int, y: int) -> int:\n    return x + y\n\nprint(add_numbers(5, 15))",
      "fontSize": 28,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "\ndef debug_decorator(func):\n    \n    def wrapper(*args, **kwargs):\n        print(\"Вызов функции: \", func.__name__)\n        print(\"Аргументы: \", args, kwargs)\n        result = func(*args, **kwargs)\n        print(\"Результат: \", result)\n        return result\n    return wrapper\n    \n\n@debug_decorator\ndef add_numbers(x: int, y: int) -> int:\n    return x + y\n\nprint(add_numbers(5, 15))",
      "autoResize": true,
      "lineHeight": 1.25
    },
