      "seed": 453987015,
      "version": 124,
      "versionNonce": 637183495,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1775037397273,
      "link": null,
      "locked": false,
      "text": "words: list[str] = [\"apple\", \"banana\", \"kiwi\", \"orange\", \"pear\"]\n\n# Альтернативное решение\ncurrent_step: int = 0\ncurrent_index: int = 0\nlenght_word: int = len(words)\nwhile current_step != lenght_word:\n    if len(words[current_index]) < 6:\n        words.pop(current_index)\n        current_step = current_step + 1\n    else:\n        words[current_index] = words[current_index].upper()\n        current_index = current_index + 1\n        current_step = current_step + 1\n\nreport: str = \"Ко-во слов больше 5 символов = {}\\nСами значения: {}\".format(\n    len(words), words\n)\nprint(report)",
      "fontSize": 36,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "words: list[str] = [\"apple\", \"banana\", \"kiwi\", \"orange\", \"pear\"]\n\n# Альтернативное решение\ncurrent_step: int = 0\ncurrent_index: int = 0\nlenght_word: int = len(words)\nwhile current_step != lenght_word:\n    if len(words[current_index]) < 6:\n        words.pop(current_index)\n        current_step = current_step + 1\n    else:\n        words[current_index] = words[current_index].upper()\n        current_index = current_index + 1\n        current_step = current_step + 1\n\nreport: str = \"Ко-во слов больше 5 символов = {}\\nСами значения: {}\".format(\n    len(words), words\n)\nprint(report)",
      "autoResize": true,
      "lineHeight": 1.25
    },
