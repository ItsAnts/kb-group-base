      "updated": 1775036422934,
      "link": null,
      "locked": false,
      "text": "numbers: list[int] = [10, 20, 30, 40, 50]\n# // 01\nprint(numbers[0] + numbers[4])\nprint(numbers[0] + numbers[-1])\n# // 02\nprint(numbers[1] + numbers[3])\nprint(numbers[1] + numbers[-2])\n# // 03\nnumbers[0] = numbers[0] + 5\nnumbers[-1] = numbers[-1] - 5",
      "fontSize": 36,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "numbers: list[int] = [10, 20, 30, 40, 50]\n# // 01\nprint(numbers[0] + numbers[4])\nprint(numbers[0] + numbers[-1])\n# // 02\nprint(numbers[1] + numbers[3])\nprint(numbers[1] + numbers[-2])\n# // 03\nnumbers[0] = numbers[0] + 5\nnumbers[-1] = numbers[-1] - 5",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "b83-APN2BknCcNH1XPXp4",
      "type": "text",
      "x": -3991.6878273468074,
      "y": 2011.0641905484438,
      "width": 1568.2667236328125,
      "height": 855,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bOW",
