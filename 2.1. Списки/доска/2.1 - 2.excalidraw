      "link": null,
      "locked": false,
      "text": "words: list[str] = [\"red\", \"green\", \"blue\", \"yellow\", \"white\", \"black\"] \nwords.inster(2, \"orange\")\nprint(words)\n# [\"red\", \"green\", \"orange\",\"blue\", \"yellow\", \"white\", \"black\"]\nnew_words = []\nnew_words.extend(words[:1])\nprint(new_words)\n# [\"red\", \"green\"]\nnew_words.append(\"orange\")\nprint(new_words)\n# [\"red\", \"green\", \"orange\"]\nnew_words.extend(words[2:])\nprint(new_words)\n# [\"red\", \"green\", \"orange\",\"blue\", \"yellow\", \"white\", \"black\"]\nprint(new_words[3]\n# \"blue\"",
      "fontSize": 36,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "words: list[str] = [\"red\", \"green\", \"blue\", \"yellow\", \"white\", \"black\"] \nwords.inster(2, \"orange\")\nprint(words)\n# [\"red\", \"green\", \"orange\",\"blue\", \"yellow\", \"white\", \"black\"]\nnew_words = []\nnew_words.extend(words[:1])\nprint(new_words)\n# [\"red\", \"green\"]\nnew_words.append(\"orange\")\nprint(new_words)\n# [\"red\", \"green\", \"orange\"]\nnew_words.extend(words[2:])\nprint(new_words)\n# [\"red\", \"green\", \"orange\",\"blue\", \"yellow\", \"white\", \"black\"]\nprint(new_words[3]\n# \"blue\"",
      "autoResize": true,
      "lineHeight": 1.25
    },
